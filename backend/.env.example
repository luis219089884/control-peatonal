# ── Django ──────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-this-in-dev-use-long-random-string-in-production

# Local: localhost,127.0.0.1
# Railway: *.railway.app,tu-proyecto.up.railway.app
ALLOWED_HOSTS=127.0.0.1,localhost

# Local frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Producción (Vercel) — descomentar y ajustar:
# CORS_ALLOWED_ORIGINS=https://control-peatonal.vercel.app
# CSRF_TRUSTED_ORIGINS=https://control-peatonal.vercel.app

# ── PostgreSQL local ────────────────────────────────────
DB_NAME=control_Peatonal
DB_USER=postgres
DB_PASSWORD=123
DB_HOST=localhost
DB_PORT=5432
DB_SSL=False

# ── BD fuente (Fase 4 reset) — PostgreSQL LOCAL con catálogo oficial ──
# Usar con: python manage.py reset_bd_fase4 --confirm --from-source-db
# (mientras DB_HOST apunta a Railway/cloud)
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=control_Peatonal
SOURCE_DB_USER=postgres
SOURCE_DB_PASSWORD=123

# CORS / frontend (recuperación de contraseña — enlace en email)
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL Supabase (producción) ───────────────────
# DB_HOST=db.xxxxx.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=tu-password-supabase
# DB_SSL=True
